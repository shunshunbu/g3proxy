---
# ============================================================
# g3proxy FTP over HTTP CONNECT 审计器配置
# ============================================================

name: ftp_auditor

# 协议检测配置
protocol_inspection:
  data0_buffer_size: 16KB
  inspect_max_depth: 5
  data0_wait_timeout: 10s
  data0_read_timeout: 5s
  data0_size_limit:
    ftp_server_greeting_msg: 2KB

# HTTP/1.1 拦截配置
h1_interception:
  req_hasbody: true
  req_body_min_size: 8

# ICAP REQMOD 服务配置（用于 FTP 上传审计）
# 需替换为实际的 ICAP 服务器地址
icap_reqmod_service: icap://127.0.0.1:1344/echo

# 审计采样比例
application_audit_ratio: 1.0
